#!/usr/bin/env bash
set -euo pipefail

display="${WECHAT_DESKTOP_DISPLAY:-:20}"
screen="${WECHAT_DESKTOP_SIZE:-1200x800}"
state_dir="$HOME/.cache/wechat-desktop"
config_file="${XDG_CONFIG_HOME:-$HOME/.config}/wsl-wechat-bridge/config"
openbox_config_dir="$state_dir/openbox"
openbox_config_file="$openbox_config_dir/rc.xml"
tint2_config_dir="$state_dir/tint2"
tint2_config_file="$tint2_config_dir/tint2rc"
mkdir -p "$state_dir"
chmod 700 "$state_dir" 2>/dev/null || true
printf '%s\n' "$display" >"$state_dir/display"
uid="$(id -u)"

read_config_value() {
  local key="$1" line value
  [ -r "$config_file" ] || return 1

  while IFS= read -r line; do
    line="${line%%#*}"
    case "$line" in
      "$key="*)
        value="${line#*=}"
        value="${value%\"}"
        value="${value#\"}"
        value="${value%\'}"
        value="${value#\'}"
        printf '%s\n' "$value"
        return 0
        ;;
    esac
  done <"$config_file"

  return 1
}

config_value() {
  local key="$1" default="${2:-}" value
  value="$(printenv "$key" 2>/dev/null || true)"
  if [ -n "$value" ]; then
    printf '%s\n' "$value"
    return 0
  fi

  if value="$(read_config_value "$key" 2>/dev/null)"; then
    printf '%s\n' "$value"
    return 0
  fi

  printf '%s\n' "$default"
}

config_truthy() {
  local key="$1" default="${2:-0}" value
  value="$(config_value "$key" "$default")"
  case "$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]')" in
    1|true|yes|on|enabled) return 0 ;;
    *) return 1 ;;
  esac
}

positive_int() {
  local value="$1" default="$2"
  case "$value" in
    ''|*[!0-9]*) printf '%s\n' "$default" ;;
    0) printf '%s\n' "$default" ;;
    *) printf '%s\n' "$value" ;;
  esac
}

log_max_bytes="$(positive_int "$(config_value WSL_WECHAT_LOG_MAX_BYTES "${WSL_WECHAT_LOG_MAX_BYTES:-}")" 5242880)"
log_backups="$(positive_int "$(config_value WSL_WECHAT_LOG_BACKUPS "${WSL_WECHAT_LOG_BACKUPS:-}")" 2)"
clipboard_ttl_seconds="$(positive_int "$(config_value WSL_WECHAT_CLIPBOARD_TTL_SECONDS "${WSL_WECHAT_CLIPBOARD_TTL_SECONDS:-}")" 3600)"
export WSL_WECHAT_LOG_MAX_BYTES="$log_max_bytes"
export WSL_WECHAT_LOG_BACKUPS="$log_backups"
export WSL_WECHAT_CLIPBOARD_TTL_SECONDS="$clipboard_ttl_seconds"

rotate_log() {
  local file="$1" i
  [ "$log_max_bytes" -gt 0 ] || return 0
  [ "$log_backups" -gt 0 ] || return 0
  [ -f "$file" ] || return 0
  [ "$(wc -c <"$file" 2>/dev/null || echo 0)" -lt "$log_max_bytes" ] && return 0

  i=$((log_backups - 1))
  while [ "$i" -ge 1 ]; do
    if [ -f "$file.$i" ]; then
      mv -f "$file.$i" "$file.$((i + 1))" 2>/dev/null || true
    fi
    i=$((i - 1))
  done
  mv -f "$file" "$file.1" 2>/dev/null || true
}

prepare_openbox_config() {
  mkdir -p "$openbox_config_dir"
  chmod 700 "$openbox_config_dir" 2>/dev/null || true

  if command -v python3 >/dev/null 2>&1 && [ -r /etc/xdg/openbox/rc.xml ]; then
    if python3 - /etc/xdg/openbox/rc.xml "$openbox_config_file" <<'PY'
import os
import sys
import xml.etree.ElementTree as ET

src, dst = sys.argv[1], sys.argv[2]
tree = ET.parse(src)
root = tree.getroot()
ns_uri = root.tag.split("}", 1)[0][1:] if root.tag.startswith("{") else ""
if ns_uri:
    ET.register_namespace("", ns_uri)
ns = {"ob": ns_uri} if ns_uri else {}


def q(name):
    return f"{{{ns_uri}}}{name}" if ns_uri else name


def local(tag):
    return tag.rsplit("}", 1)[-1]


def find(parent, name):
    return parent.find(f"ob:{name}" if ns_uri else name, ns)


def ensure(parent, name, text):
    elem = find(parent, name)
    if elem is None:
        elem = ET.SubElement(parent, q(name))
    elem.text = text
    return elem


desktops = find(root, "desktops")
if desktops is None:
    desktops = ET.SubElement(root, q("desktops"))
ensure(desktops, "number", "1")
ensure(desktops, "firstdesk", "1")
ensure(desktops, "popupTime", "0")

names = find(desktops, "names")
if names is None:
    names = ET.SubElement(desktops, q("names"))
for child in list(names):
    names.remove(child)
name = ET.SubElement(names, q("name"))
name.text = "desktop1"

for parent in root.iter():
    for child in list(parent):
        if local(child.tag) not in {"keybind", "mousebind"}:
            continue
        has_desktop_action = False
        for action in child.iter():
            if local(action.tag) == "action" and action.attrib.get("name") in {"GoToDesktop", "SendToDesktop"}:
                has_desktop_action = True
                break
        if has_desktop_action:
            parent.remove(child)

tmp = dst + ".tmp"
tree.write(tmp, encoding="UTF-8", xml_declaration=True)
os.replace(tmp, dst)
PY
    then
      chmod 600 "$openbox_config_file" 2>/dev/null || true
      return 0
    fi
  fi

  if [ -r /etc/xdg/openbox/rc.xml ]; then
    cp /etc/xdg/openbox/rc.xml "$openbox_config_file"
    sed -i -E \
      -e 's#<number>[0-9]+</number>#<number>1</number>#' \
      -e 's#<popupTime>[0-9]+</popupTime>#<popupTime>0</popupTime>#' \
      "$openbox_config_file" 2>/dev/null || true
  else
    cat >"$openbox_config_file" <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <focus><focusNew>yes</focusNew><followMouse>no</followMouse><focusLast>yes</focusLast></focus>
  <placement><policy>Smart</policy><center>yes</center><monitor>Primary</monitor></placement>
  <theme><name>Clearlooks</name><titleLayout>NLIMC</titleLayout><keepBorder>yes</keepBorder></theme>
  <desktops><number>1</number><firstdesk>1</firstdesk><names><name>desktop1</name></names><popupTime>0</popupTime></desktops>
  <margins><top>0</top><bottom>0</bottom><left>0</left><right>0</right></margins>
  <mouse>
    <context name="Client">
      <mousebind button="Left" action="Press"><action name="Focus"/><action name="Raise"/></mousebind>
      <mousebind button="Middle" action="Press"><action name="Focus"/><action name="Raise"/></mousebind>
      <mousebind button="Right" action="Press"><action name="Focus"/><action name="Raise"/></mousebind>
    </context>
    <context name="Desktop">
      <mousebind button="Left" action="Press"><action name="Focus"/><action name="Raise"/></mousebind>
      <mousebind button="Right" action="Press"><action name="Focus"/><action name="Raise"/></mousebind>
    </context>
  </mouse>
</openbox_config>
EOF
  fi

  chmod 600 "$openbox_config_file" 2>/dev/null || true
}

prepare_tint2_config() {
  mkdir -p "$tint2_config_dir"
  chmod 700 "$tint2_config_dir" 2>/dev/null || true

  if [ -r /etc/xdg/tint2/tint2rc ]; then
    awk '
      /^taskbar_mode[[:space:]]*=/ {
        print "taskbar_mode = single_desktop"
        next
      }
      /^taskbar_name[[:space:]]*=/ {
        print "taskbar_name = 0"
        next
      }
      /^taskbar_always_show_all_desktop_tasks[[:space:]]*=/ {
        print "taskbar_always_show_all_desktop_tasks = 1"
        next
      }
      { print }
    ' /etc/xdg/tint2/tint2rc >"$tint2_config_file.tmp" && mv -f "$tint2_config_file.tmp" "$tint2_config_file"
    chmod 600 "$tint2_config_file" 2>/dev/null || true
  fi
}

enforce_single_desktop() {
  if command -v wmctrl >/dev/null 2>&1; then
    wmctrl -l 2>/dev/null | awk '$2 != "-1" { print $1 }' | while IFS= read -r window_id; do
      [ -n "$window_id" ] || continue
      wmctrl -i -r "$window_id" -t 0 >/dev/null 2>&1 || true
    done
    wmctrl -s 0 >/dev/null 2>&1 || true
    wmctrl -n 1 >/dev/null 2>&1 || true
    wmctrl -s 0 >/dev/null 2>&1 || true
  elif command -v xdotool >/dev/null 2>&1; then
    xdotool set_desktop 0 >/dev/null 2>&1 || true
    xdotool set_num_desktops 1 >/dev/null 2>&1 || true
    xdotool set_desktop 0 >/dev/null 2>&1 || true
  fi
}

resolve_wechat_command() {
  local configured

  configured="${WECHAT_DESKTOP_COMMAND:-}"
  if [ -z "$configured" ]; then
    configured="$(read_config_value WECHAT_COMMAND || true)"
  fi

  if [ -n "$configured" ]; then
    if command -v "$configured" >/dev/null 2>&1 || [ -x "$configured" ]; then
      printf '%s\n' "$configured"
      return 0
    fi
    echo "Configured WeChat command is not executable: $configured" >&2
    echo "Edit $config_file or set WECHAT_DESKTOP_COMMAND." >&2
    return 1
  fi

  if command -v wechat >/dev/null 2>&1; then
    command -v wechat
    return 0
  fi

  if [ -x /usr/bin/wechat ]; then
    printf '%s\n' /usr/bin/wechat
    return 0
  fi

  echo "Linux WeChat command was not found." >&2
  echo "Install official Linux WeChat, or set WECHAT_COMMAND in $config_file." >&2
  return 1
}

wechat_command="$(resolve_wechat_command)"

display_num="${display#:}"
display_num="${display_num%%.*}"

if ! xdpyinfo -display "$display" >/dev/null 2>&1; then
  rm -f "/tmp/.X${display_num}-lock" "/tmp/.X11-unix/X${display_num}" 2>/dev/null || true
  rotate_log "$state_dir/xephyr.log"
  nohup Xephyr "$display" -screen "$screen" -resizeable -ac -br -title "WeChat Desktop" \
    >"$state_dir/xephyr.log" 2>&1 &
  echo $! >"$state_dir/xephyr.pid"

  for _ in $(seq 1 60); do
    if xdpyinfo -display "$display" >/dev/null 2>&1; then
      break
    fi
    sleep 0.1
  done
fi

if ! xdpyinfo -display "$display" >/dev/null 2>&1; then
  echo "Failed to start nested X display $display" >&2
  tail -n 80 "$state_dir/xephyr.log" >&2 || true
  exit 1
fi

export DISPLAY="$display"
unset WAYLAND_DISPLAY

export XMODIFIERS="@im=fcitx"
export GTK_IM_MODULE=fcitx
export QT_IM_MODULE=fcitx
export SDL_IM_MODULE=fcitx
export INPUT_METHOD=fcitx
export XIM_PROGRAM=fcitx5
export QT_QPA_PLATFORM=xcb
export QT_XCB_NO_XI2=1

if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]; then
  eval "$(dbus-launch --sh-syntax)"
fi

prepare_openbox_config
if ! ps -p "$(cat "$state_dir/openbox.pid" 2>/dev/null || echo 0)" >/dev/null 2>&1; then
  rotate_log "$state_dir/openbox.log"
  nohup openbox --config-file "$openbox_config_file" >"$state_dir/openbox.log" 2>&1 &
  echo $! >"$state_dir/openbox.pid"
  sleep 0.5
else
  openbox --reconfigure >/dev/null 2>&1 || true
fi
enforce_single_desktop

start_panel() {
  if ! command -v tint2 >/dev/null 2>&1; then
    return 0
  fi

  prepare_tint2_config
  if ps -p "$(cat "$state_dir/tint2.pid" 2>/dev/null || echo 0)" >/dev/null 2>&1; then
    return 0
  fi

  rotate_log "$state_dir/tint2.log"
  if [ -r "$tint2_config_file" ]; then
    nohup tint2 -c "$tint2_config_file" >"$state_dir/tint2.log" 2>&1 &
  elif [ -r /etc/xdg/tint2/tint2rc ]; then
    nohup tint2 -c /etc/xdg/tint2/tint2rc >"$state_dir/tint2.log" 2>&1 &
  else
    nohup tint2 >"$state_dir/tint2.log" 2>&1 &
  fi
  echo $! >"$state_dir/tint2.pid"
  sleep 0.3
}

start_panel

windows_launcher_file() {
  local filename="$1"
  local localapp profile candidate

  localapp="$(cmd.exe /C echo %LOCALAPPDATA% 2>/dev/null | tr -d '\r' || true)"
  if [ -n "$localapp" ] && [[ "$localapp" != *%* ]]; then
    candidate="$(wslpath -u "${localapp}\\WslPrivate\\launchers\\${filename}" 2>/dev/null || true)"
    if [ -n "$candidate" ] && [ -f "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  fi

  profile="$(cmd.exe /C echo %USERPROFILE% 2>/dev/null | tr -d '\r' || true)"
  if [ -n "$profile" ] && [[ "$profile" != *%* ]]; then
    candidate="$(wslpath -u "${profile}\\AppData\\Local\\WslPrivate\\launchers\\${filename}" 2>/dev/null || true)"
    if [ -n "$candidate" ] && [ -f "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  fi

  candidate="/mnt/c/Users/Administrator/AppData/Local/WslPrivate/launchers/${filename}"
  if [ -f "$candidate" ]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  return 1
}

start_notice_bridge() {
  if ! config_truthy NOTICE_BRIDGE_ENABLED "1"; then
    return 0
  fi

  if ! command -v wsl-app-notify-bridge >/dev/null 2>&1; then
    return 0
  fi

  if ps -p "$(cat "$state_dir/notice-bridge.pid" 2>/dev/null || echo 0)" >/dev/null 2>&1; then
    return 0
  fi

  rotate_log "$state_dir/notice-bridge-start.log"
  nohup wsl-app-notify-bridge >"$state_dir/notice-bridge-start.log" 2>&1 &
  sleep 0.1
}

start_badge_watch() {
  local poll_seconds idle_poll_seconds args=()

  if ! config_truthy BADGE_WATCH_ENABLED "0"; then
    return 0
  fi

  if ! command -v wsl-app-badge-notify-watch >/dev/null 2>&1; then
    return 0
  fi

  if ps -p "$(cat "$state_dir/badge-notify-watch.pid" 2>/dev/null || echo 0)" >/dev/null 2>&1; then
    return 0
  fi

  args=(wsl-app-badge-notify-watch --display "$display")
  poll_seconds="$(config_value BADGE_WATCH_POLL_SECONDS "")"
  idle_poll_seconds="$(config_value BADGE_WATCH_IDLE_POLL_SECONDS "")"
  if [ -n "$poll_seconds" ]; then
    args+=(--poll-seconds "$poll_seconds")
  fi
  if [ -n "$idle_poll_seconds" ]; then
    args+=(--idle-poll-seconds "$idle_poll_seconds")
  fi

  rotate_log "$state_dir/badge-notify-watch-start.log"
  nohup "${args[@]}" >"$state_dir/badge-notify-watch-start.log" 2>&1 &
  sleep 0.1
}

start_focus_watch() {
  local helper
  if ! config_truthy FOCUS_WATCH_ENABLED "1"; then
    return 0
  fi

  helper="$(windows_launcher_file "start-focus-watch-hidden.vbs" || true)"
  if [ ! -f "$helper" ]; then
    return 0
  fi

  wscript.exe //B "$(wslpath -w "$helper")" >/dev/null 2>&1 || true
}

start_clipboard_watch() {
  local helper
  if ! config_truthy CLIPBOARD_WATCH_ENABLED "1"; then
    return 0
  fi

  helper="$(windows_launcher_file "start-clipboard-watch-hidden.vbs" || true)"
  if [ ! -f "$helper" ]; then
    return 0
  fi

  wscript.exe //B "$(wslpath -w "$helper")" >/dev/null 2>&1 || true
}

if ! pgrep -u "$uid" -x fcitx5 >/dev/null 2>&1; then
  rotate_log "$state_dir/fcitx5.log"
  nohup fcitx5 --disable=wayland --disable=waylandim -d --replace --verbose '*'=0 \
    >"$state_dir/fcitx5.log" 2>&1 || true
fi

start_notice_bridge
start_badge_watch
start_focus_watch
start_clipboard_watch

exec "$wechat_command" "$@"
