#!/usr/bin/env bash
set -euo pipefail

state_dir="$HOME/.cache/wechat-desktop"
display="${WECHAT_DESKTOP_DISPLAY:-}"
force=0
dry_run=0

usage() {
  cat <<'EOF'
Usage: wechat-desktop-stop [--force] [--dry-run]

Stops the nested WeChat Desktop session: Linux WeChat, Xephyr, openbox,
tint2, its managed input method, notification helpers, and Windows
focus/clipboard watchers.

Options:
  --force    Use SIGKILL after a short graceful shutdown attempt.
  --dry-run  Print matching processes without stopping them.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --force) force=1 ;;
    --dry-run) dry_run=1 ;;
    -h|--help) usage; exit 0 ;;
    *) usage >&2; exit 64 ;;
  esac
  shift
done

if [ -z "$display" ]; then
  display="$(cat "$state_dir/display" 2>/dev/null || true)"
fi
if [ -z "$display" ]; then
  display=":20"
fi

display_num="${display#:}"
display_num="${display_num%%.*}"
uid="$(id -u)"

windows_launcher_file() {
  local filename="$1"
  local localapp profile candidate

  localapp="$(cmd.exe /C echo %LOCALAPPDATA% 2>/dev/null | tr -d '\r' || true)"
  if [ -n "$localapp" ] && [[ "$localapp" != *%* ]]; then
    candidate="$(wslpath -u "${localapp}\\WslPrivate\\launchers\\${filename}" 2>/dev/null || true)"
    if [ -n "$candidate" ] && [ -f "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  fi

  profile="$(cmd.exe /C echo %USERPROFILE% 2>/dev/null | tr -d '\r' || true)"
  if [ -n "$profile" ] && [[ "$profile" != *%* ]]; then
    candidate="$(wslpath -u "${profile}\\AppData\\Local\\WslPrivate\\launchers\\${filename}" 2>/dev/null || true)"
    if [ -n "$candidate" ] && [ -f "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  fi

  candidate="/mnt/c/Users/Administrator/AppData/Local/WslPrivate/launchers/${filename}"
  if [ -f "$candidate" ]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  return 1
}

pid_from_file() {
  local file="$1" pattern="${2:-}" pid args owner
  pid="$(cat "$file" 2>/dev/null || true)"
  [ -n "$pid" ] || return 0
  kill -0 "$pid" 2>/dev/null || return 0
  owner="$(stat -c %u "/proc/$pid" 2>/dev/null || true)"
  [ "$owner" = "$uid" ] || return 0

  if [ -n "$pattern" ]; then
    args="$(tr '\0' ' ' <"/proc/$pid/cmdline" 2>/dev/null || ps -p "$pid" -o args= 2>/dev/null || true)"
    [ -n "$args" ] || return 0
    printf '%s\n' "$args" | grep -Eq "$pattern" || return 0
  fi

  printf '%s\n' "$pid"
}

process_env_value() {
  local pid="$1" key="$2" entry
  [ -r "/proc/$pid/environ" ] || return 1
  while IFS= read -r entry; do
    case "$entry" in
      "$key="*)
        printf '%s\n' "${entry#*=}"
        return 0
        ;;
    esac
  done < <(tr '\0' '\n' <"/proc/$pid/environ")
  return 1
}

process_on_display() {
  [ "$(process_env_value "$1" DISPLAY 2>/dev/null || true)" = "$display" ]
}

print_process_tree() {
  local root_pid="$1"
  printf '%s\n' "$root_pid"
  ps -u "$uid" -o pid=,ppid= | awk -v root="$root_pid" '
      { parent[$1] = $2 }
      END {
        for (pid in parent) {
          current = pid
          while (current in parent && parent[current] != 0) {
            if (parent[current] == root) {
              print pid
              break
            }
            current = parent[current]
          }
        }
      }
    '
}

wechat_root_for_display() {
  local proc pid owner comm
  for proc in /proc/[0-9]*; do
    pid="${proc#/proc/}"
    owner="$(stat -c %u "$proc" 2>/dev/null || true)"
    [ "$owner" = "$uid" ] || continue
    comm="$(cat "$proc/comm" 2>/dev/null || true)"
    [ "$comm" = "wechat" ] || continue
    process_on_display "$pid" || continue
    printf '%s\n' "$pid"
    return 0
  done
  return 1
}

managed_wechat_pids() {
  local proc pid owner comm exe root_pid

  root_pid="$(pid_from_file "$state_dir/wechat.pid" '(^|/)wechat([[:space:]]|$)' | head -n 1)"
  if [ -n "$root_pid" ] && ! process_on_display "$root_pid"; then
    root_pid=""
  fi
  if [ -z "$root_pid" ]; then
    root_pid="$(wechat_root_for_display 2>/dev/null || true)"
  fi
  if [ -n "$root_pid" ]; then
    print_process_tree "$root_pid"
  fi

  for proc in /proc/[0-9]*; do
    pid="${proc#/proc/}"
    owner="$(stat -c %u "$proc" 2>/dev/null || true)"
    [ "$owner" = "$uid" ] || continue
    comm="$(cat "$proc/comm" 2>/dev/null || true)"
    exe="$(readlink -f "$proc/exe" 2>/dev/null || true)"
    case "$comm" in
      wechat|WeChatAppEx|wxocr|wxplayer|wxutility|crashpad_handler) ;;
      *)
        case "$exe" in
          /opt/wechat/*) ;;
          *) continue ;;
        esac
        ;;
    esac
    process_on_display "$pid" || continue
    printf '%s\n' "$pid"
  done
}

sogou_pids() {
  local proc pid owner exe
  for proc in /proc/[0-9]*; do
    pid="${proc#/proc/}"
    owner="$(stat -c %u "$proc" 2>/dev/null || true)"
    [ "$owner" = "$uid" ] || continue
    exe="$(readlink -f "$proc/exe" 2>/dev/null || true)"
    case "$exe" in
      /opt/sogoupinyin/files/bin/sogoupinyin-service|/opt/sogoupinyin/files/bin/sogoupinyin-watchdog)
        process_on_display "$pid" || continue
        printf '%s\n' "$pid"
        ;;
    esac
  done
}

managed_fcitx_pid="$(pid_from_file "$state_dir/fcitx.pid" '(^|/)fcitx([[:space:]]|$)' | head -n 1)"
if [ -n "$managed_fcitx_pid" ] && ! process_on_display "$managed_fcitx_pid"; then
  managed_fcitx_pid=""
fi
managed_input=0
if [ -n "$managed_fcitx_pid" ]; then
  managed_input=1
fi

pids_to_stop() {
  {
    pid_from_file "$state_dir/xephyr.pid" "Xephyr .*${display}"
    pid_from_file "$state_dir/openbox.pid" "openbox"
    pid_from_file "$state_dir/tint2.pid" "tint2"
    pid_from_file "$state_dir/notice-bridge.pid" "wsl-app-notify-bridge"
    pid_from_file "$state_dir/notification-daemon.pid" "wsl-app-notification-daemon"
    pid_from_file "$state_dir/focus-sink.pid" "wsl-focus-sink"
    pid_from_file "$state_dir/badge-notify-watch.pid" "wsl-app-badge-notify-watch"
    managed_wechat_pids
    pgrep -u "$uid" -f "Xephyr ${display}" 2>/dev/null || true
    if [ "$managed_input" -eq 1 ]; then
      if kill -0 "$managed_fcitx_pid" 2>/dev/null; then
        printf '%s\n' "$managed_fcitx_pid"
      fi
      sogou_pids
    fi
  } | awk 'NF && !seen[$1]++ { print $1 }'
}

cleanup_sogou_queues() {
  local queue queue_pattern

  if { [ -n "$managed_fcitx_pid" ] && kill -0 "$managed_fcitx_pid" 2>/dev/null; } ||
     [ -n "$(sogou_pids)" ]; then
    return 0
  fi

  if ! mountpoint -q /dev/mqueue 2>/dev/null; then
    sudo -n mkdir -p /dev/mqueue >/dev/null 2>&1 || return 0
    sudo -n mount -t mqueue none /dev/mqueue >/dev/null 2>&1 ||
      mountpoint -q /dev/mqueue 2>/dev/null || return 0
  fi

  queue_pattern="SOGOUPINYIN-SOGOU-IME-IPC-MQ-*-${uid}-${display_num}"
  while IFS= read -r queue; do
    [ -n "$queue" ] || continue
    rm -f -- "$queue" 2>/dev/null || true
  done < <(
    find /dev/mqueue -mindepth 1 -maxdepth 1 -user "$uid" \
      -name "$queue_pattern" -print 2>/dev/null
  )
}

stop_windows_helper() {
  local filename="$1" helper
  helper="$(windows_launcher_file "$filename" || true)"
  if [ -f "$helper" ]; then
    cmd.exe /C "$(wslpath -w "$helper")" >/dev/null 2>&1 || true
  fi
}

if [ "$dry_run" -eq 1 ]; then
  printf 'display=%s\n' "$display"
  mapfile -t pids < <(pids_to_stop)
  if [ "${#pids[@]}" -eq 0 ]; then
    printf 'no matching processes\n'
  else
    pid_csv="$(IFS=,; printf '%s' "${pids[*]}")"
    ps -p "$pid_csv" -o pid=,args= 2>/dev/null || true
  fi
  exit 0
fi

export DISPLAY="$display"
unset WAYLAND_DISPLAY

stop_windows_helper "stop-focus-watch.cmd"
stop_windows_helper "stop-clipboard-watch.cmd"

if xdpyinfo -display "$display" >/dev/null 2>&1; then
  wmctrl -cx wechat.wechat >/dev/null 2>&1 || true
  sleep 1
fi

if [ "$managed_input" -eq 1 ] && command -v fcitx-remote >/dev/null 2>&1; then
  DISPLAY="$display" fcitx-remote -e >/dev/null 2>&1 || true
  sleep 1
fi

mapfile -t pids < <(pids_to_stop)

if [ "${#pids[@]}" -gt 0 ]; then
  kill -TERM "${pids[@]}" 2>/dev/null || true
  sleep 2
fi

still_running=()
for pid in "${pids[@]:-}"; do
  if kill -0 "$pid" 2>/dev/null; then
    still_running+=("$pid")
  fi
done

if [ "${#still_running[@]}" -gt 0 ]; then
  if [ "$force" -eq 1 ]; then
    kill -KILL "${still_running[@]}" 2>/dev/null || true
    sleep 1
  else
    printf 'still running after SIGTERM; rerun with --force to send SIGKILL:\n' >&2
    pid_csv="$(IFS=,; printf '%s' "${still_running[*]}")"
    ps -p "$pid_csv" -o pid=,args= >&2 2>/dev/null || printf '%s\n' "${still_running[@]}" >&2
    exit 1
  fi
fi

still_running=()
for pid in "${pids[@]:-}"; do
  if kill -0 "$pid" 2>/dev/null; then
    still_running+=("$pid")
  fi
done

if [ "${#still_running[@]}" -gt 0 ]; then
  printf 'still running after SIGKILL:\n' >&2
  pid_csv="$(IFS=,; printf '%s' "${still_running[*]}")"
  ps -p "$pid_csv" -o pid=,args= >&2 2>/dev/null || printf '%s\n' "${still_running[@]}" >&2
  exit 1
fi

rm -f \
  "$state_dir/xephyr.pid" \
  "$state_dir/openbox.pid" \
  "$state_dir/tint2.pid" \
  "$state_dir/notice-bridge.pid" \
  "$state_dir/notification-daemon.pid" \
  "$state_dir/focus-sink.pid" \
  "$state_dir/badge-notify-watch.pid" \
  "$state_dir/fcitx.pid" \
  "$state_dir/wechat.pid" \
  "$state_dir/notice-bridge.seen" \
  "/tmp/.X${display_num}-lock" \
  "/tmp/.X11-unix/X${display_num}" \
  2>/dev/null || true

cleanup_sogou_queues

printf 'stopped display=%s\n' "$display"
